# =============================================================================
# SmokeShop Platform — Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# Database (required)
# PostgreSQL connection string with PostGIS extension enabled
DATABASE_URL=postgresql://user:password@localhost:5432/smokeshop

# Auth.js (required)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# Google OAuth (optional — needed for Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis / Upstash (optional in dev — required in prod for rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# File Storage (Sprint 2+)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Payments — Authorize.net (Sprint 4)
# AUTHORIZE_NET_API_LOGIN_ID=
# AUTHORIZE_NET_TRANSACTION_KEY=
# AUTHORIZE_NET_CLIENT_KEY=

# Age Verification — Veriff (Sprint 4)
# VERIFF_API_KEY=
# VERIFF_API_SECRET=

# Delivery — DoorDash Drive (Sprint 4)
# DOORDASH_DEVELOPER_ID=
# DOORDASH_KEY_ID=
# DOORDASH_SIGNING_SECRET=

# Monitoring (Sprint 6)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
